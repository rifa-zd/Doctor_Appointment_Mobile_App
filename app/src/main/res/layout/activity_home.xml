<?xml version="1.0" encoding="utf-8"?>
<ScrollView  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home"
    android:background="@color/beige"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- App Title & LOGO -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:src="@drawable/app_logo"
            android:contentDescription="Logo" />

<!--        //guest prompt-->
        <TextView
            android:id="@+id/tvGuestMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please Register to Interact!!"
            android:textColor="@color/orange"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"/>


        <!-- Welcome Section -->
        <TextView
            android:id="@+id/tvwelcomeTextHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="------"
            android:textSize="14sp"
            android:textColor="@color/dark_teal"
            android:background="@color/beige"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:visibility="gone"/>

        <!-- Search Section -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search for doctor, specialist"
            android:padding="10dp"
            android:cursorVisible="false"
            android:layout_marginTop="12dp"
            android:background="@color/white" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter location"
            android:padding="10dp"
            android:cursorVisible="false"
            android:layout_marginTop="8dp"
            android:background="@color/white" />

<!--        Find doc Button-->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@color/dark_teal"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:gravity="center">

            <Button
                android:id="@+id/btnFindDoc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Find Doctors"
                android:textColor="@color/white"
                android:backgroundTint="@color/dark_teal"
                android:textStyle="bold"
                android:textSize="15sp"/>
        </LinearLayout>


        <!-- Healthcare Services Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Healthcare Services"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/dark_teal"
            android:layout_marginTop="20dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvCardiology"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤️ Cardiology"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvNeurology"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧠 Neurology"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvDental"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🦷 Dental"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvMedicine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💊 Medicine"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvPediatrics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶 Pediatrics"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvGeneral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🩺 General"
                    android:padding="8dp" />

            </LinearLayout>

        </HorizontalScrollView>


        <!-- Doctor List -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Available Doctors"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/dark_teal"
            android:layout_marginTop="20dp" />

        <ListView
            android:id="@+id/doctorsList"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp" />


        <!-- See More Button -->
        <TextView
            android:id="@+id/tvSeeMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="See More..."
            android:layout_gravity="end"
            android:padding="8dp"
            android:textSize="14sp"
            android:textColor="@color/dark_teal"/>

        <!-- Promotional Offers Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="70dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="12dp"
            app:cardMaxElevation="16dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFA333">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Get 10% off on your first appointment!"
                    android:textSize="15sp"
                    android:textColor="@color/beige"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="12dp"
                    />

                <!-- Left Arrow -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="‹"
                    android:textSize="24sp"
                    android:textColor="#80FFFFFF"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:textStyle="bold"
                    android:padding="8dp" />

                <!-- Right Arrow -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:textStyle="bold"
                    android:padding="8dp" />

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <!-- Simple dots to indicate slider -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/orange"
                android:layout_margin="2dp" />

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#50000000"
                android:layout_margin="2dp" />

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#50000000"
                android:layout_margin="2dp" />

        </LinearLayout>


        <!-- Quick Links -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvBookAppointHome"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/rounded_outline_button"
                    android:gravity="center"
                    android:text="Book an Appoinment"
                    android:textColor="@color/dark_teal"
                    android:padding="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvViewAppointHome"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/rounded_outline_button"
                    android:gravity="center"
                    android:text="View Appoinments"
                    android:textColor="@color/dark_teal"
                    android:layout_marginLeft="14dp"
                    android:padding="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/tvDocListHome"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/rounded_outline_button"
                    android:gravity="center"
                    android:text="Doctor List"
                    android:textColor="@color/dark_teal"

                    android:padding="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvContactHome"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/rounded_outline_button"
                    android:gravity="center"
                    android:text="Contact Support"
                    android:textColor="@color/dark_teal"
                    android:padding="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="14dp"/>


                <TextView
                    android:id="@+id/tvAboutUsHome"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/rounded_outline_button"
                    android:gravity="center"
                    android:text="About Us"
                    android:textColor="@color/dark_teal"
                    android:layout_marginLeft="14dp"
                    android:padding="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</ScrollView >