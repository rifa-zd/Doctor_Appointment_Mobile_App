<?xml version="1.0" encoding="utf-8"?>
<ScrollView  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".signup"
    android:background="@drawable/gradient_bg"
    android:fillViewport="true"
    android:layout_marginTop="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- App Logo + Name -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">


            <ImageView
                android:id="@+id/logo"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:contentDescription="App Logo"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:id="@+id/appName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="4dp"
                android:layout_toRightOf="@id/logo"
                android:shadowColor="@color/teal"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="CuraSync"
                android:textColor="@color/dark_teal"
                android:textSize="16sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- Heading -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:shadowColor="@color/orange"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="Sign-Up"
            android:textColor="@color/dark_teal"
            android:textSize="28sp"
            android:textStyle="bold" />

<!--        //progress bar for firbase-->
        <ProgressBar
            android:id="@+id/progressBarSign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/orange"
            android:layout_marginTop="10dp"
            android:visibility="gone"/>

        <!-- Full Name -->
        <EditText
            android:id="@+id/etFullNameSign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@color/white"
            android:hint="Full Name"
            android:inputType="textPersonName"
            android:padding="10dp" />

        <!-- Email -->
        <EditText
            android:id="@+id/etEmailSign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@color/white"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:padding="10dp" />

        <!-- Birth of date -->
<!--        focusable="false" and clickable="true" ensures the user cannot type into the field but can tap it.-->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="0dp">

            <EditText
                android:id="@+id/etBirthDateSign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Birth of date"
                android:background="@color/white"
                android:paddingEnd="40dp"
                android:focusable="true"
                android:clickable="false"
                android:cursorVisible="false"
                android:padding="10dp"
                android:layout_centerVertical="true" />

            <!-- Calendar Icon -->
            <ImageView
                android:id="@+id/ivCalendarIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/calendar"
                android:clickable="true"
                android:layout_alignEnd="@id/etBirthDateSign"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp" />
        </RelativeLayout>

        <!--        <EditText-->
<!--            android:id="@+id/etBirthDateSign"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="10dp"-->
<!--            android:background="@android:drawable/edit_text"-->
<!--            android:focusable="true"-->
<!--            android:hint="Birth of date"-->
<!--            android:padding="10dp"-->
<!--            android:drawableRight="@drawable/calendar"/>-->

        <!-- Phone Number -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <!-- Country Code -->
            <TextView
                android:id="@+id/tvCountryCode"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/white"
                android:clickable="true"
                android:drawableEnd="@android:drawable/arrow_down_float"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:text="+880"
                android:textColor="#000000"
                android:textSize="16sp" />

            <!-- Phone Number -->
            <EditText
                android:id="@+id/etPhoneSign"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/white"
                android:hint="Phone Number"
                android:inputType="phone"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Set Password -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/etPasswordSign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:hint="Set Password"
                android:inputType="numberPassword"
                android:padding="10dp"
                android:paddingEnd="40dp" />

            <ImageView
                android:id="@+id/ivShowPassSign"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:contentDescription="Show Password"
                android:focusable="true"
                android:src="@android:drawable/ic_menu_view" />

        </RelativeLayout>

        <!-- Retype Password -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/etRetypePassSign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:hint="Retype Password"
                android:inputType="numberPassword"
                android:padding="10dp"
                android:paddingEnd="40dp" />

            <ImageView
                android:id="@+id/ivShowRetypePassSign"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:contentDescription="Show Password"
                android:focusable="true"
                android:src="@android:drawable/ic_menu_view" />

        </RelativeLayout>

        <!-- Register Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@color/dark_teal"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/dark_teal"
                android:text="Register"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:enabled="true"/>
        </LinearLayout>


        <!-- Already have account -->
        <TextView
            android:id="@+id/tvLogin_inSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Already have an account? Login"
            android:textColor="@color/beige"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView >